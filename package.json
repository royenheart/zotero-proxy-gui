{
  "name": "zotero-proxy-gui",
  "version": "0.1.0",
  "description": "A Zotero 7/8 plugin providing a visual proxy management interface with multi-config presets and one-click switching",
  "private": true,
  "config": {
    "prefsPrefix": "extensions.zotero-proxy-gui"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/royenheart/zotero-proxy-gui.git"
  },
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "node scripts/build-multi.mjs",
    "build:v7": "node scripts/build-multi.mjs v7",
    "build:v8": "node scripts/build-multi.mjs v8",
    "release": "zotero-plugin release",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "zotero-plugin-scaffold": "^0.4.0",
    "zotero-types": "^1.3.23",
    "typescript": "^5.4.5",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0"
  }
}
